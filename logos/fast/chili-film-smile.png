    <div class="news-nl-divider" aria-hidden="true"></div>

    <!-- COLONNA DESTRA: Newsletter -->
    <div class="news-nl-col news-nl-col--nl">

      <div class="nl-inner">
        <div class="nl-badge">
          <i class="fa fa-envelope-open-text"></i>
          Newsletter
        </div>
        <h2 class="nl-title">Resta sempre aggiornato</h2>
        <p class="nl-sub">
          Articoli su sviluppo web, tips PHP/MySQL, novità dal mondo tech.<br>
          Niente spam — solo contenuti che vale la pena leggere.
        </p>
        <form class="nl-form" id="nl-form" novalidate>
          <input type="text" name="website" id="nl-honey" tabindex="-1" autocomplete="off" aria-hidden="true">
          <input type="hidden" name="csrf_token" id="nl-csrf" value="0539ea461f9d150d0a36070fc42e812fd365a63e9833304a734f856b04cbd4f5">
          <div class="nl-field-wrap">
            <i class="fa fa-envelope nl-field-icon"></i>
            <input type="email" name="email" id="nl-email" class="nl-input"
              placeholder="La tua email..." autocomplete="email" required>
            <button type="submit" class="nl-btn" id="nl-submit">
              <span class="nl-btn-text">Iscriviti</span>
              <i class="fa fa-arrow-right nl-btn-icon"></i>
              <span class="nl-spinner" aria-hidden="true"></span>
            </button>
          </div>
          <div class="nl-msg" id="nl-msg" role="alert" aria-live="polite"></div>
          <p class="nl-privacy">
            <i class="fa fa-lock"></i>
            Confermando riceverai una mail di verifica.
          </p>
        </form>
      </div>

      <div class="nl-orb nl-orb-l" aria-hidden="true"></div>
      <div class="nl-orb nl-orb-r" aria-hidden="true"></div>

    </div><!-- /col nl -->

  </div><!-- /news-nl-wrap -->

</section>

<script>
(function(){
  var form    = document.getElementById('nl-form');
  var input   = document.getElementById('nl-email');
  var msg     = document.getElementById('nl-msg');
  var btn     = document.getElementById('nl-submit');
  var lastSub = 0;
  form.addEventListener('submit', function(e){
    e.preventDefault();
    var now = Date.now();
    if (now - lastSub < 8000) return;
    lastSub = now;
    var email = input.value.trim();
    var honey = document.getElementById('nl-honey').value;
    if (!email) { showMsg('Inserisci la tua email.', 'error'); return; }
    btn.disabled = true; btn.classList.add('loading');
    msg.className = 'nl-msg'; msg.textContent = '';
    var fd = new FormData();
    fd.append('email', email);
    fd.append('website', honey);
    fd.append('csrf_token', document.getElementById('nl-csrf').value);
    fetch('newsletter_subscribe.php', { method: 'POST', body: fd })
      .then(function(r){ return r.json(); })
      .then(function(data){
        showMsg(data.message, data.status);
        if (data.status === 'success' || data.status === 'already') input.value = '';
      })
      .catch(function(){ showMsg('Errore di rete. Riprova tra poco.', 'error'); })
      .finally(function(){ btn.disabled = false; btn.classList.remove('loading'); });
  });
  function showMsg(text, type){
    msg.textContent = text;
    msg.className = 'nl-msg nl-msg--' + type + ' nl-msg--visible';
  }
})();
</script>


