<script>
(function(){
  // Slider solo su desktop — su mobile rimane fisso su 12.jpg
  if (window.innerWidth >= 1025) {
    var sl  = document.querySelectorAll('.slides .slide');
    var cur = 0;
    setInterval(function(){
      sl[cur].classList.remove('active');
      cur = (cur + 1) % sl.length;
      sl[cur].classList.add('active');
    }, 5000);
  }

  // Ricerca blog
  var inp = document.getElementById('hero-search-input');
  var btn = document.getElementById('hero-search-btn');
  function doSearch(){
    var q = inp.value.trim();
    if (q !== '') {
      window.location.href = 'blog.php?q=' + encodeURIComponent(q);
    }
  }
  btn.addEventListener('click', doSearch);
  inp.addEventListener('keydown', function(e){
    if (e.key === 'Enter') doSearch();
  });
})();
</script>

