.cb-top   { display: flex; align-items: flex-start; gap: 1rem; }
.cb-icon  {
  flex-shrink: 0;
  width: 38px; height: 38px; border-radius: 10px;
  background: rgba(208,24,171,.12);
  border: 1px solid rgba(208,24,171,.25);
  display: flex; align-items: center; justify-content: center;
  color: #d018ab; font-size: .95rem;
}
.cb-title {
  font-size: .82rem; font-weight: 600;
  color: #f5f2ff; margin: 0 0 .3rem;
  letter-spacing: -.01em;
}
.cb-desc {
  font-size: .74rem; font-weight: 300;
  color: rgba(232,228,240,.65);
  line-height: 1.65; margin: 0;
}
.cb-desc strong { font-weight: 500; color: rgba(232,228,240,.85); }
.cb-link {
  color: #d018ab; text-decoration: underline;
  text-underline-offset: 2px; white-space: nowrap;
}
.cb-link:hover { color: #e066cc; }
.cb-actions {
  display: flex; gap: .65rem; justify-content: flex-end;
}
.cb-btn {
  padding: .52rem 1.25rem; border-radius: 40px;
  font-family: 'Inter', sans-serif;
  font-size: .76rem; font-weight: 500; letter-spacing: .02em;
  cursor: pointer; border: none; transition: .2s;
  white-space: nowrap;
}
.cb-btn--reject {
  background: rgba(255,255,255,.07);
  border: 1px solid rgba(255,255,255,.14);
  color: rgba(232,228,240,.7);
}
.cb-btn--reject:hover {
  background: rgba(255,255,255,.12);
  color: #f5f2ff;
}
.cb-btn--accept {
  background: linear-gradient(135deg, #d018ab, #8c0f70);
  color: #fff;
  box-shadow: 0 3px 14px rgba(208,24,171,.35);
}
.cb-btn--accept:hover { filter: brightness(1.1); transform: translateY(-1px); }

@media (max-width: 480px) {
  #cookie-banner { bottom: 1rem; padding: 1.1rem 1.1rem; border-radius: 14px; }
  .cb-actions { flex-direction: column; }
  .cb-btn { width: 100%; text-align: center; padding: .62rem 1rem; }
  .cb-btn--accept { order: -1; }
}
</style>

<script>
(function(){
  var banner  = document.getElementById('cookie-banner');
  var btnAcc  = document.getElementById('cb-accept');
  var btnRej  = document.getElementById('cb-reject');

  // Mostra con leggero delay
  setTimeout(function(){ banner.classList.add('cb-show'); }, 800);

  function setCookie(name, value, days){
    var d = new Date();
    d.setTime(d.getTime() + days * 86400000);
    document.cookie = name + '=' + value + ';expires=' + d.toUTCString() + ';path=/;SameSite=Lax';
  }

  function hideBanner(){
    banner.classList.remove('cb-show');
    banner.classList.add('cb-hide');
    setTimeout(function(){ banner.remove(); }, 500);
  }

  // Accetta tutti — attiva GA
  btnAcc.addEventListener('click', function(){
    setCookie('df_cookie_consent', 'all', 365);
    hideBanner();
    // Sblocca Google Analytics
    if (typeof gtag === 'function') {
      gtag('consent', 'update', { analytics_storage: 'granted' });
    }
  });

  // Solo necessari — GA rimane bloccato
  btnRej.addEventListener('click', function(){
    setCookie('df_cookie_consent', 'necessary', 365);
    hideBanner();
    if (typeof gtag === 'function') {
      gtag('consent', 'update', { analytics_storage: 'denied' });
    }
  });
})();
</script>
<!-- ══════════════════════════════════════════════
     PWA — Service Worker + Banner Android
════════════════════════════════════════════════ -->

<!-- Banner installazione Android -->
<div id="pwa-banner" role="dialog" aria-modal="true" aria-label="Installa l'app" hidden>
  <div class="pwa-banner-inner">
    <img class="pwa-banner-icon" src="/assets/icons/icon-72x72.png" alt="DF Developer" width="48" height="48">
    <div class="pwa-banner-text">
      <strong>DF Developer</strong>
      <span>Installa il sito come app sul tuo telefono</span>
    </div>
    <div class="pwa-banner-actions">
      <button class="pwa-btn pwa-btn--dismiss" id="pwa-dismiss" aria-label="Chiudi">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
      <button class="pwa-btn pwa-btn--install" id="pwa-install">
        Installa <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
      </button>
    </div>
  </div>
</div>

<style>
#pwa-banner {
  position: fixed;
  bottom: 1.25rem;
  left: 50%;
  transform: translateX(-50%) translateY(140%);
  z-index: 9990;
  width: min(94vw, 480px);
  background: rgba(13, 8, 28, 0.96);
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
  border: 1px solid rgba(208,24,171,.3);
  border-radius: 16px;
  box-shadow: 0 8px 40px rgba(0,0,0,.7), 0 1px 0 rgba(208,24,171,.15) inset;
  padding: .9rem 1.1rem;
  transition: transform .45s cubic-bezier(.22,1,.36,1), opacity .35s ease;
  opacity: 0;
  font-family: 'Inter', sans-serif;
}
#pwa-banner:not([hidden]) { display: block; }
#pwa-banner.pwa-show {
  transform: translateX(-50%) translateY(0);
  opacity: 1;
}
#pwa-banner.pwa-hide {
  transform: translateX(-50%) translateY(140%);
  opacity: 0;
}
.pwa-banner-inner {
  display: flex; align-items: center; gap: .85rem;
}
.pwa-banner-icon {
  width: 48px; height: 48px; border-radius: 12px;
  flex-shrink: 0;
  border: 1px solid rgba(208,24,171,.2);
  object-fit: cover;
}
.pwa-banner-text {
  flex: 1; min-width: 0;
  display: flex; flex-direction: column; gap: .12rem;
}
.pwa-banner-text strong {
  font-size: .82rem; font-weight: 600; color: #f7f4ff;
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
.pwa-banner-text span {
  font-size: .71rem; font-weight: 300;
  color: rgba(232,228,240,.5);
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
.pwa-banner-actions {
  display: flex; align-items: center; gap: .5rem; flex-shrink: 0;
}
.pwa-btn {
  display: inline-flex; align-items: center; justify-content: center;
  gap: .35rem; border: none; cursor: pointer;
  font-family: 'Inter', sans-serif; transition: .2s;
  border-radius: 40px;
}
.pwa-btn--dismiss {
  width: 30px; height: 30px;
  background: rgba(255,255,255,.07);
  border: 1px solid rgba(255,255,255,.12) !important;
  color: rgba(232,228,240,.5);
  border-radius: 50% !important;
}
.pwa-btn--dismiss:hover { background: rgba(255,255,255,.14); color: #f7f4ff; }
.pwa-btn--install {
  padding: .45rem 1rem;
  background: linear-gradient(135deg, #d018ab, #8c0f70);
  color: #fff; font-size: .74rem; font-weight: 500;
  box-shadow: 0 3px 12px rgba(208,24,171,.4);
}
.pwa-btn--install:hover { filter: brightness(1.1); transform: translateY(-1px); }

@media (max-width: 400px) {
  #pwa-banner { padding: .8rem .9rem; }
  .pwa-banner-text span { display: none; }
}
</style>

<script>
(function(){
  'use strict';

  // ── Registra Service Worker ──────────────────────
  if ('serviceWorker' in navigator) {
    window.addEventListener('load', function(){
      navigator.serviceWorker.register('/sw.js', { scope: '/' })
        .catch(function(err){ console.warn('SW registration failed:', err); });
    });
  }

  // ── Banner installazione Android ─────────────────
  var banner      = document.getElementById('pwa-banner');
  var btnInstall  = document.getElementById('pwa-install');
  var btnDismiss  = document.getElementById('pwa-dismiss');
  var deferredEvt = null;

  // Non mostrare se già dismissato nelle ultime 2 settimane
  var dismissed = localStorage.getItem('pwa_banner_dismissed');
  if (dismissed && Date.now() - parseInt(dismissed) < 14 * 86400000) return;

  // Cattura evento beforeinstallprompt (solo Android/Chrome)
  window.addEventListener('beforeinstallprompt', function(e){
    e.preventDefault();
    deferredEvt = e;
    banner.removeAttribute('hidden');
    setTimeout(function(){
      banner.classList.add('pwa-show');
    }, 3000); // compare dopo 3 secondi
  });

  // Nascondi se già installata
  window.addEventListener('appinstalled', function(){
    hideBanner();
    localStorage.setItem('pwa_banner_dismissed', Date.now().toString());
  });

  function hideBanner(){
    banner.classList.remove('pwa-show');
    banner.classList.add('pwa-hide');
    setTimeout(function(){ banner.setAttribute('hidden', ''); }, 500);
  }

  btnInstall.addEventListener('click', function(){
    if (!deferredEvt) return;
    deferredEvt.prompt();
    deferredEvt.userChoice.then(function(choice){
      deferredEvt = null;
      hideBanner();
      if (choice.outcome === 'accepted') {
        localStorage.setItem('pwa_banner_dismissed', Date.now().toString());
      }
    });
  });

  btnDismiss.addEventListener('click', function(){
    hideBanner();
    localStorage.setItem('pwa_banner_dismissed', Date.now().toString());
  });

})();
</script>