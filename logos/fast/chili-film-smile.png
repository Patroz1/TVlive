<script>
function initScroller(wrapId, trackId, prevId, nextId, cardClass) {
  var wrap  = document.getElementById(wrapId);
  var track = document.getElementById(trackId);
  var prev  = document.getElementById(prevId);
  var next  = document.getElementById(nextId);
  if (!wrap || !track) return;

  var GAP = 16;

  function setCardWidths() {
    var cards = track.querySelectorAll('.' + cardClass);
    if (!cards.length) return;
    if (window.innerWidth < 1025) {
      cards.forEach(function(c){ c.style.width = ''; });
      return;
    }
    var w = Math.floor((wrap.clientWidth - GAP * 2) / 3);
    cards.forEach(function(c){ c.style.width = w + 'px'; });
  }

  function pageW() {
    var card = track.querySelector('.' + cardClass);
    if (!card) return wrap.clientWidth;
    return (card.offsetWidth + GAP) * 3;
  }

  function updateArrows() {
    if (!prev || !next) return;
    prev.classList.toggle(cardClass.replace('-card','') + '-arrow--hidden', wrap.scrollLeft <= 4);
    next.classList.toggle(cardClass.replace('-card','') + '-arrow--hidden', wrap.scrollLeft >= wrap.scrollWidth - wrap.clientWidth - 4);
  }

  setCardWidths();
  updateArrows();
  window.addEventListener('resize', function(){ setCardWidths(); updateArrows(); });

  if (prev) prev.addEventListener('click', function(){ wrap.scrollBy({ left: -pageW(), behavior: 'smooth' }); });
  if (next) next.addEventListener('click', function(){ wrap.scrollBy({ left:  pageW(), behavior: 'smooth' }); });
  wrap.addEventListener('scroll', updateArrows, { passive: true });

  /* Drag solo su desktop — non interferisce con touch Safari */
  if (!('ontouchstart' in window)) {
    var isDown = false, startX = 0, scrollStart = 0;
    wrap.addEventListener('mousedown', function(e){
      isDown = true; startX = e.pageX; scrollStart = wrap.scrollLeft;
      wrap.style.cursor = 'grabbing'; wrap.style.userSelect = 'none';
    });
    document.addEventListener('mouseup', function(){
      if (!isDown) return; isDown = false;
      wrap.style.cursor = ''; wrap.style.userSelect = '';
    });
    document.addEventListener('mousemove', function(e){
      if (!isDown) return; e.preventDefault();
      wrap.scrollLeft = scrollStart - (e.pageX - startX);
    });
  }
}

initScroller('blog-wrap', 'blog-track', 'blog-prev', 'blog-next', 'blog-card');
</script>

