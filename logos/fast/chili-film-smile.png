<!-- ── PAGE TRANSITION OVERLAY ── -->
<div id="page-transition" aria-hidden="true"></div>

<script>
// Loader + transizioni pagina — inline per eseguire prima del CSS
(function(){
  var loader = document.getElementById('page-loader');
  var overlay = document.getElementById('page-transition');

  // Nascondi loader quando pagina è pronta
  function hideLoader(){
    loader.classList.add('loader-done');
    setTimeout(function(){ loader.style.display = 'none'; }, 600);
  }
  if (document.readyState === 'complete') {
    setTimeout(hideLoader, 800);
  } else {
    window.addEventListener('load', function(){ setTimeout(hideLoader, 400); });
  }

  // Transizione su click link interni
  document.addEventListener('click', function(e){
    var a = e.target.closest('a');
    if (!a) return;
    var href = a.getAttribute('href');
    if (!href || href.startsWith('#') || href.startsWith('mailto:') ||
        href.startsWith('tel:') || href.startsWith('http') ||
        a.target === '_blank') return;
    // Se l'href contiene un'ancora (#), lascia il browser gestire normalmente
    if (href.indexOf('#') !== -1) return;
    e.preventDefault();
    overlay.classList.add('transition-out');
    setTimeout(function(){ window.location.href = href; }, 350);
  });

  // Fade-in all'arrivo
  window.addEventListener('pageshow', function(){
    overlay.classList.remove('transition-out');
  });
})();
</script>

